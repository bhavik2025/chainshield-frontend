# ─────────────────────────────────────────────────────────────────────
# ChainShield — frontend environment variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────

# Backend API base URL (local dev or Cloud Run URL)
VITE_API_URL=http://localhost:8000

# ── Firebase project config ──────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → Web
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
